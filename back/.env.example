# Django Settings
SECRET_KEY=your-secret-key-here-generate-with-generate_secret_key.py
DEBUG=False
ALLOWED_HOSTS=your-railway-app.railway.app,localhost,127.0.0.1

# Database (Railway will provide this automatically)
DATABASE_URL=postgresql://user:password@host:port/database

# DigitalOcean Spaces (Optional - set USE_SPACES=False to disable)
USE_SPACES=False
DO_SPACES_KEY=your-spaces-key
DO_SPACES_SECRET=your-spaces-secret
DO_SPACES_BUCKET_NAME=your-bucket-name
DO_SPACES_ENDPOINT_URL=https://sfo3.digitaloceanspaces.com
DO_SPACES_REGION=sfo3
DO_SPACES_CDN_DOMAIN=your-bucket.sfo3.cdn.digitaloceanspaces.com

# CORS Settings
CORS_ALLOWED_ORIGINS=https://bellrockholdings.org,https://www.bellrockholdings.org,http://localhost:5173,http://localhost:3000
FRONTEND_URL=https://bellrockholdings.org

# CSRF Settings
CSRF_TRUSTED_ORIGINS=https://real-production-4319.up.railway.app,https://bellrockholdings.org,https://www.bellrockholdings.org

# Railway URLs (automatically set by Railway)
RAILWAY_STATIC_URL=
CUSTOM_DOMAIN=
